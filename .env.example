# Database
POSTGRES_USER=pebble
POSTGRES_PASSWORD=pebble_dev_password
POSTGRES_DB=pebble
DATABASE_URL=postgresql+asyncpg://pebble:pebble_dev_password@localhost:5432/pebble

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Plaid
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox

# AI providers (LiteLLM is the unified client)
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=
GEMINI_API_KEY=
DEFAULT_CHAT_MODEL=anthropic/claude-haiku-4-5-20251001

# Encryption (Fernet key for Plaid access tokens)
ENCRYPTION_KEY=generate-with-cryptography-fernet-generate-key

# Twilio (SMS verification)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=your-twilio-verify-service-sid
