# Database
POSTGRES_USER=pebble
POSTGRES_PASSWORD=pebble_dev_password
POSTGRES_DB=pebble
DATABASE_URL=postgresql+asyncpg://pebble:pebble_dev_password@localhost:5432/pebble

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Plaid
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Encryption (Fernet key for Plaid access tokens)
ENCRYPTION_KEY=generate-with-cryptography-fernet-generate-key
