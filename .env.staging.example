# Pebble Staging Environment Variables
# Copy to .env.staging and fill in real values (never commit secrets)

# --- Database (provided by Terraform output) ---
DATABASE_URL=postgresql+asyncpg://pebble:PASSWORD@RDS_ENDPOINT:5432/pebble

# --- Redis (provided by Terraform output) ---
REDIS_URL=redis://ELASTICACHE_ENDPOINT:6379/0

# --- Auth ---
JWT_SECRET_KEY=generate-a-strong-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Plaid ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# --- Anthropic (AI assistant) ---
ANTHROPIC_API_KEY=

# --- App ---
ENVIRONMENT=staging
DEBUG=false
